# =============================================================================
# Dom'Atic — .gitignore
# Python + Node + Docker project
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
mosquitto/config/passwd

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
.venv/
venv/
env/
pip-wheel-metadata/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.pyo
*.pyd
.hypothesis/

# ---------------------------------------------------------------------------
# Node / Next.js
# ---------------------------------------------------------------------------
node_modules/
.next/
.nuxt/
out/
dist/
.cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Docker volumes (if mounted locally)
# ---------------------------------------------------------------------------
postgres_data/
redis_data/
mosquitto_data/
mosquitto_log/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
log/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
.coverage
htmlcov/
coverage.xml
*.cover
