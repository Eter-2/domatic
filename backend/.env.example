# ─────────────────────────────────────────────────────────────────────────────
# Dom'Atic Backend — Environment Configuration
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string using the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://domatic:changeme@localhost:5432/domatic

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for MQTT → WebSocket pub/sub fan-out.
REDIS_URL=redis://localhost:6379/0

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Unique client identifier for this backend instance.
MQTT_CLIENT_ID=domatic-backend
# Topic subscription filter. '#' subscribes to all topics.
MQTT_SUBSCRIBE_TOPIC=#

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to enable strict security checks (e.g. strong SECRET_KEY guard).
ENVIRONMENT=development

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Pi-hole Integration ───────────────────────────────────────────────────────
PIHOLE_ENABLED=false
PIHOLE_URL=http://pihole.local
# Found in Pi-hole admin panel: Settings → API / Web interface
PIHOLE_API_TOKEN=
# How often (seconds) to poll Pi-hole for DNS query data.
PIHOLE_POLL_INTERVAL_SECONDS=60

# ── Home Assistant Integration ────────────────────────────────────────────────
HA_ENABLED=false
HA_URL=http://homeassistant.local:8123
# Long-lived access token from HA profile page.
HA_TOKEN=

# ── Security Settings ─────────────────────────────────────────────────────────
# Comma-separated cloud domains to flag in DNS/payload inspection.
SECURITY_CLOUD_DOMAINS=amazonaws.com,cloud.tuya.com,iot.tuya.com,smartlife.io,meethue.com,lifx.io
# Number of MQTT messages per minute before rate-limit alert is raised.
SECURITY_ALERT_MQTT_THRESHOLD=100

# ── Data Retention ────────────────────────────────────────────────────────────
# Maximum rows in mqtt_messages table (oldest pruned automatically).
MQTT_MESSAGE_MAX_ROWS=10000
# Days to keep device state history (used for partition pruning queries).
DEVICE_STATE_RETENTION_DAYS=90

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the browser frontend.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
