# =============================================================================
# Dom'Atic — Environment Variables
# Copy to .env and fill in your values before running `make up`
# NEVER commit .env to version control
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change_me_strong_password

# ---------------------------------------------------------------------------
# Backend secrets
# ---------------------------------------------------------------------------
# 64-character hex string — generate with: openssl rand -hex 32
SECRET_KEY=change_me_64_char_hex_string

# MQTT broker password for the backend service user
MQTT_PASSWORD=change_me_mqtt_password

# ---------------------------------------------------------------------------
# Pi-hole integration (optional)
# ---------------------------------------------------------------------------
PIHOLE_ENABLED=false
PIHOLE_URL=http://192.168.1.1
PIHOLE_API_TOKEN=

# ---------------------------------------------------------------------------
# Home Assistant integration (optional)
# ---------------------------------------------------------------------------
HA_ENABLED=false
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
